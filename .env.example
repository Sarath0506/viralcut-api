# Copy to .env — never commit .env

NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://postgres:PASSWORD@HOST.proxy.rlwy.net:PORT/railway

JWT_SECRET=change-me-to-at-least-32-chars-long-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
PASSWORD_RESET_TTL=1h

# Unified portal (local dev: apps/portal on port 3000)
CORS_ORIGINS=http://localhost:3000
WEB_URL=http://localhost:3000

BRAND_INVITE_TTL=7d
WITHDRAWAL_FEE_BPS=150

OTP_DEV_LOG=true
# Dev only: any phone accepts this OTP (no WhatsApp). Run `pnpm prisma:seed` for demo logins.
OTP_DEV_BYPASS_CODE=000000
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v22.0
WHATSAPP_OTP_TEMPLATE_NAME=login_otp
WHATSAPP_OTP_TEMPLATE_LANGUAGE=en_US
WHATSAPP_OTP_TEMPLATE_HAS_BUTTON=false

# Preferred on Railway (HTTPS). Same re_... key as Resend SMTP password.
RESEND_API_KEY=
EMAIL_FROM=

# Optional local fallback when RESEND_API_KEY is unset (blocked on Railway Hobby).
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=

S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# apps/portal/.env → VITE_API_URL=http://localhost:3001
