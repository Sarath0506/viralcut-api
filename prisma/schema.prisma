generator client {

  provider = "prisma-client-js"

}



datasource db {

  provider = "postgresql"

  url      = env("DATABASE_URL")

}



enum UserRole {

  creator

  brand

  admin

}



enum KycStatus {

  not_started

  pending

  verified

  rejected

}



enum CampaignStatus {

  draft

  live

  paused

  closed

}



enum CampaignWizardStep {

  basics

  brief

  payout

  review

}



enum CampaignOwnership {

  brand_created

  admin_created

}



enum CampaignInviteStatus {

  pending

  accepted

  expired

  revoked

}



enum SubmissionStatus {

  draft_submitted

  under_review

  approved

  awaiting_live_link

  live_tracking

  payout_pending

  paid

  rejected

}



enum FormatDeliverableStatus {

  draft_pending

  under_review

  draft_rejected

  draft_approved

  live_submitted

}



enum TransactionType {

  earning_credit

  withdrawal_debit

  fee_debit

  adjustment

}



enum WithdrawalStatus {

  pending

  processing

  completed

  failed

}



model User {

  id           String    @id @default(cuid())

  role         UserRole

  email        String?   @unique

  phone        String?   @unique

  passwordHash String?   @map("password_hash")

  displayName  String?   @map("display_name")

  username     String?   @unique

  fixedOtpCode String?   @map("fixed_otp_code") @db.VarChar(6)

  kycStatus        KycStatus @default(not_started) @map("kyc_status")

  termsAcceptedAt  DateTime? @map("terms_accepted_at")

  createdAt        DateTime  @default(now()) @map("created_at")

  updatedAt    DateTime  @updatedAt @map("updated_at")



  brandProfile              BrandProfile?

  wallet                    Wallet?

  submissions               Submission[]

  campaignParticipations    CampaignParticipation[]

  deliverablesReviewed      FormatDeliverable[]     @relation("DeliverableReviewedBy")

  payoutMethods             PayoutMethod[]

  withdrawals               Withdrawal[]

  refreshTokens             RefreshToken[]

  passwordResetTokens       PasswordResetToken[]

  campaignsCreated          Campaign[]         @relation("CampaignCreatedBy")

  campaignInvitesSent       CampaignInvite[]   @relation("CampaignInviteInviter")

  campaignInvitesAccepted   CampaignInvite[]   @relation("CampaignInviteAcceptor")



  @@map("users")

}



model OtpSession {

  id        String   @id @default(cuid())

  phone     String

  codeHash  String   @map("code_hash")

  expiresAt DateTime @map("expires_at")

  attempts  Int      @default(0)

  createdAt DateTime @default(now()) @map("created_at")



  @@index([phone, expiresAt])

  @@map("otp_sessions")

}



model RefreshToken {

  id        String   @id @default(cuid())

  userId    String   @map("user_id")

  tokenHash String   @unique @map("token_hash")

  expiresAt DateTime @map("expires_at")

  revokedAt DateTime? @map("revoked_at")

  createdAt DateTime @default(now()) @map("created_at")



  user User @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@index([userId])

  @@map("refresh_tokens")

}



model PasswordResetToken {

  id        String    @id @default(cuid())

  userId    String    @map("user_id")

  tokenHash String    @unique @map("token_hash")

  expiresAt DateTime  @map("expires_at")

  usedAt    DateTime? @map("used_at")

  createdAt DateTime  @default(now()) @map("created_at")



  user User @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@index([userId])

  @@map("password_reset_tokens")

}



model BrandProfile {

  id          String   @id @default(cuid())

  userId      String   @unique @map("user_id")

  companyName String   @map("company_name")

  logoUrl     String?  @map("logo_url")

  createdAt   DateTime @default(now()) @map("created_at")

  updatedAt   DateTime @updatedAt @map("updated_at")



  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  campaigns Campaign[]



  @@map("brand_profiles")

}



model Campaign {

  id               String              @id @default(cuid())

  brandProfileId   String?             @map("brand_profile_id")

  createdByUserId  String?             @map("created_by_user_id")

  ownership        CampaignOwnership   @default(brand_created)

  wizardStep       CampaignWizardStep  @default(basics) @map("wizard_step")

  inviteAcceptedAt DateTime?           @map("invite_accepted_at")

  title            String

  category         String?

  platform         String              @default("instagram_reel")

  platforms        String[]            @default([])

  status           CampaignStatus      @default(draft)

  brief            String              @db.Text

  briefHook        String?             @map("brief_hook") @db.Text

  doRules          String?             @map("do_rules") @db.Text

  avoidRules       String?             @map("avoid_rules") @db.Text

  sourceAssets     Json?               @map("source_assets")

  referenceAssets  Json?               @map("reference_assets")

  coverImageUrl    String?             @map("cover_image_url")

  productUrl       String?             @map("product_url")

  ratePer1kPaise   Int                 @map("rate_per_1k_paise")

  maxPayoutPaise   Int                 @map("max_payout_paise")

  budgetPaise      Int                 @map("budget_paise")

  budgetUsedPaise  Int                 @default(0) @map("budget_used_paise")

  startDate        DateTime?           @map("start_date")

  createdAt        DateTime            @default(now()) @map("created_at")

  updatedAt        DateTime            @updatedAt @map("updated_at")



  brandProfile BrandProfile?    @relation(fields: [brandProfileId], references: [id], onDelete: SetNull)

  createdBy    User?            @relation("CampaignCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  submissions  Submission[]

  participations CampaignParticipation[]

  invites      CampaignInvite[]



  @@index([status])

  @@index([brandProfileId])

  @@index([ownership])

  @@map("campaigns")

}



model CampaignInvite {

  id               String               @id @default(cuid())

  campaignId       String               @map("campaign_id")

  email            String

  tokenHash        String               @unique @map("token_hash")

  status           CampaignInviteStatus @default(pending)

  expiresAt        DateTime             @map("expires_at")

  acceptedAt       DateTime?            @map("accepted_at")

  invitedByUserId  String               @map("invited_by_user_id")

  acceptedByUserId String?              @map("accepted_by_user_id")

  createdAt        DateTime             @default(now()) @map("created_at")



  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  invitedBy   User     @relation("CampaignInviteInviter", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  acceptedBy  User?    @relation("CampaignInviteAcceptor", fields: [acceptedByUserId], references: [id], onDelete: SetNull)



  @@index([campaignId, status])

  @@index([email])

  @@map("campaign_invites")

}



model Submission {

  id                 String           @id @default(cuid())

  campaignId         String           @map("campaign_id")

  creatorId          String           @map("creator_id")

  status             SubmissionStatus @default(draft_submitted)

  mediaType          String           @default("video") @map("media_type")

  draftDriveUrl      String?          @map("draft_drive_url")

  draftStorageKey    String?          @map("draft_storage_key")

  liveReelUrl        String?          @map("live_reel_url")

  eligibleViews      Int              @default(0) @map("eligible_views")

  estimatedPaise     Int              @default(0) @map("estimated_paise")

  rejectionReason    String?          @map("rejection_reason")

  submittedAt        DateTime         @default(now()) @map("submitted_at")

  approvedAt         DateTime?        @map("approved_at")

  liveLinkAt         DateTime?        @map("live_link_at")

  paidAt             DateTime?        @map("paid_at")

  updatedAt          DateTime         @updatedAt @map("updated_at")



  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  creator  User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)



  @@index([creatorId, status])

  @@index([campaignId, status])

  @@map("submissions")

}



model CampaignParticipation {

  id                String   @id @default(cuid())

  campaignId        String   @map("campaign_id")

  creatorId         String   @map("creator_id")

  platformsSnapshot String[] @map("platforms_snapshot")

  joinedAt          DateTime @default(now()) @map("joined_at")

  updatedAt         DateTime @updatedAt @map("updated_at")



  campaign     Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  creator      User                @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  deliverables FormatDeliverable[]



  @@unique([campaignId, creatorId])

  @@index([creatorId])

  @@map("campaign_participations")

}



model FormatDeliverable {

  id                 String                  @id @default(cuid())

  participationId    String                  @map("participation_id")

  platform           String

  draftDriveUrl      String?                 @map("draft_drive_url")

  livePostUrl        String?                 @map("live_post_url")

  status             FormatDeliverableStatus @default(draft_pending)

  rejectionReason    String?                 @map("rejection_reason")

  draftSubmittedAt   DateTime?               @map("draft_submitted_at")

  draftReviewedAt    DateTime?               @map("draft_reviewed_at")

  liveSubmittedAt    DateTime?               @map("live_submitted_at")

  reviewedByUserId   String?                 @map("reviewed_by_user_id")

  updatedAt          DateTime                @updatedAt @map("updated_at")



  participation CampaignParticipation @relation(fields: [participationId], references: [id], onDelete: Cascade)

  reviewedBy    User?                 @relation("DeliverableReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)



  @@unique([participationId, platform])

  @@index([participationId])

  @@index([status])

  @@map("format_deliverables")

}



model Wallet {

  id             String   @id @default(cuid())

  userId         String   @unique @map("user_id")

  availablePaise Int      @default(0) @map("available_paise")

  pendingPaise   Int      @default(0) @map("pending_paise")

  lifetimePaise  Int      @default(0) @map("lifetime_paise")

  updatedAt      DateTime @updatedAt @map("updated_at")



  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]



  @@map("wallets")

}



model Transaction {

  id          String          @id @default(cuid())

  walletId    String          @map("wallet_id")

  type        TransactionType

  amountPaise Int             @map("amount_paise")

  referenceId String?         @map("reference_id")

  note        String?

  createdAt   DateTime        @default(now()) @map("created_at")



  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)



  @@index([walletId, createdAt])

  @@map("transactions")

}



model PayoutMethod {

  id            String   @id @default(cuid())

  userId        String   @map("user_id")

  type          String

  label         String

  accountMasked String   @map("account_masked")

  isDefault     Boolean  @default(false) @map("is_default")

  createdAt     DateTime @default(now()) @map("created_at")



  user User @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@index([userId])

  @@map("payout_methods")

}



model Withdrawal {

  id              String           @id @default(cuid())

  userId          String           @map("user_id")

  amountPaise     Int              @map("amount_paise")

  feePaise        Int              @map("fee_paise")

  netPaise        Int              @map("net_paise")

  status          WithdrawalStatus @default(pending)

  payoutMethodId  String?          @map("payout_method_id")

  idempotencyKey  String?          @unique @map("idempotency_key")

  createdAt       DateTime         @default(now()) @map("created_at")

  processedAt     DateTime?        @map("processed_at")



  user User @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@index([userId, status])

  @@map("withdrawals")

}


